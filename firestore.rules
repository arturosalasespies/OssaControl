rules_version = '2';

// ============================================
// Reglas de seguridad de Firestore — OSSA Control
//
// CÓMO DESPLEGAR:
//   1. Instala Firebase CLI: npm install -g firebase-tools
//   2. En la raíz del proyecto: firebase login
//   3. firebase init firestore  (selecciona el proyecto OSSA Control)
//   4. firebase deploy --only firestore:rules
//
// LÓGICA DE ROLES:
//   - Admin: identificado por email conocido (admin@ossa.com) en el token de Auth
//   - Alumno: puede leer únicamente su propio documento
//
// TIPOS DE ID EN LA COLECCIÓN "users":
//   - Documento con ID = UID  → alumno registrado vía SignUpScreen
//   - Documento con ID = email → alumno creado por el admin (AdminViewModel.registrarAlumno)
//   Ambos casos están cubiertos en la regla de lectura del alumno.
//
// LIMITACIÓN CONOCIDA:
//   El email del admin está hardcodeado igual que en SignUpScreen.kt.
//   Si en el futuro hay más admins, la solución correcta es usar
//   Firebase Custom Claims (requiere Cloud Functions / Admin SDK).
// ============================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{docId} {

      // El admin puede leer y escribir cualquier documento
      allow read, write: if request.auth != null
                         && request.auth.token.email == 'admin@ossa.com';

      // Un alumno puede leer únicamente su propio documento.
      // Cubre los dos casos de ID:
      //   · docId == UID  (registro vía SignUpScreen)
      //   · resource.data.email == email del token (creado por el admin)
      allow read: if request.auth != null
                  && (request.auth.uid == docId
                      || resource.data.email == request.auth.token.email);

      // Los alumnos no pueden escribir: solo el admin edita los datos
    }
  }
}
